# Copy to .env and adjust. Never commit .env (it is gitignored).
# On the server this file lives at docker/.env and is auto-loaded by `docker compose`
# (the deployer runs `docker compose --project-directory docker up` with no --env-file).

# Custom App Templates. Points at the raw URL of docker/portainer/templates/templates.json in
# this repo — edit that file and push to update templates without rebuilding the image.
# Leave empty to use Portainer's built-in template list.
PORTAINER_TEMPLATES_URL=https://raw.githubusercontent.com/uye-ltd/infra-portainer/main/docker/portainer/templates/templates.json

# Host port for the HTTP UI. Bound to 127.0.0.1 only — reach it via SSH tunnel or a
# host-level reverse proxy. See README "Accessing the UI".
PORTAINER_HTTP_PORT=9000

# Socket-proxy capability toggles. 0 = denied, 1 = allowed.
# EXEC (container console/attach) and BUILD (image builds from the UI) are the main
# container-escape vectors, so they default to off. Enable only if you need those features.
PORTAINER_ENABLE_EXEC=0
PORTAINER_ENABLE_BUILD=0

# Enable the Swarm API groups (NODES/SERVICES/TASKS/SWARM) — only when managing a Swarm cluster.
PORTAINER_SWARM=0

# Extension escape hatch: extra flags appended to the Portainer command
# (e.g. "--logout-hostname portainer.example.com" or edge/logging flags).
PORTAINER_EXTRA_ARGS=

# Admin password is NOT pre-seeded here (a bcrypt hash contains '$', which breaks compose
# interpolation, and a password-file bind mount would break under the deployer). Set the admin
# password on first login over the SSH tunnel. If Portainer's initial-setup window times out,
# run `docker restart portainer` and try again. See README "First-time server setup".
